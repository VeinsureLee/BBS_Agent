{
  "description": "论坛结构总结后的向量库（每版面一份总结）",
  "data_role": "static",
  "collection_name": "bbs_static_knowledge",
  "persist_directory": "vector_db/static",
  "md5_hex_store": "vector_db/static/md5.txt",
  "data_path": "data/web_structure",
  "k": 10,
  "allow_knowledge_file_type": ["txt", "pdf", "json"],
  "chunk_size": 500,
  "chunk_overlap": 50,
  "separators": ["\n\n", "\n", ".", "!", "?", "。", "！", "？", " ", ""]
}
