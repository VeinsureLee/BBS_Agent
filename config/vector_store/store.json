{
  "description": "用户上传数据的向量库",
  "data_role": "store",
  "collection_name": "usr_knowledge_base",
  "persist_directory": "vector_db/store",
  "md5_hex_store": "vector_db/store/md5.txt",
  "data_path": "data/store",
  "k": 10,
  "allow_knowledge_file_type": ["txt", "pdf", "json"],
  "chunk_size": 500,
  "chunk_overlap": 50,
  "separators": ["\n\n", "\n", ".", "!", "?", "。", "！", "？", " ", ""]
}
